{
  "builds": [
    {
      "src": "app.php",
      "use": "vercel-php@0.7.4",
      "config": { "includeFiles": "{includes/**,*.php}" }
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/app.php" }
  ]
}
